{
    "name": "la-maison/reservation-system",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/yaml": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/form": "^7.0",
        "symfony/validator": "^7.0",
        "symfony/security-csrf": "^7.0",
        "doctrine/orm": "^2.17",
        "doctrine/doctrine-bundle": "^2.10",
        "twig/twig": "^3.8",
        "doctrine/doctrine-migrations-bundle": "^3.7"
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.60",
        "symfony/test-pack": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "extra": {
        "symfony": {
            "require": "^7.0"
        }
    }
