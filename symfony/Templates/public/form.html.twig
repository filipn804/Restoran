{% extends 'base.html.twig' %}

{% block body %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Make a Reservation</h4>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="mb-3">
                        {{ form_label(form.fullName) }}
                        {{ form_widget(form.fullName, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.fullName) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.phone) }}
                        {{ form_widget(form.phone, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.phone) }}
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col">
                            {{ form_label(form.date) }}
                            {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.date) }}
                        </div>
                        <div class="col">
                            {{ form_label(form.time) }}
                            {{ form_widget(form.time, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.time) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.partySize) }}
                        {{ form_widget(form.partySize, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.partySize) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(form.specialRequest) }}
                        {{ form_widget(form.specialRequest, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                        {{ form_errors(form.specialRequest) }}
                    </div>

                    <div class="form-check mb-3">
                        {{ form_widget(form.privateDining, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.privateDining, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        {{ form_errors(form.privateDining) }}
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Reserve</button>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}